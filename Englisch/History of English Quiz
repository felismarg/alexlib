<!DOCTYPE html>
<html lang="de">
<head>
<meta charset="UTF-8">
<title>History of English — Klausurtrainer</title>
<style>
  :root{
    --parchment:#efe7d6;
    --ink:#2b2418;
    --ink-soft:#5a4f3c;
    --rune:#7a5c3e;
    --rune-dark:#4e3a26;
    --ok:#3f6b47;
    --bad:#9c3b3b;
    --gold:#a9822f;
    --card:#f7f2e5;
    --line:#d8cba9;
  }
  *{box-sizing:border-box;}
  body{
    margin:0;
    background:
      radial-gradient(1200px 600px at 10% -10%, #f4ecd8 0%, transparent 60%),
      var(--parchment);
    color:var(--ink);
    font-family: "Iowan Old Style","Palatino Linotype", Georgia, serif;
    min-height:100vh;
    padding:32px 16px 80px;
  }
  .wrap{max-width:760px;margin:0 auto;}

  header{
    text-align:center;
    margin-bottom:28px;
    position:relative;
  }
  .runes{
    font-family: Georgia, serif;
    letter-spacing:6px;
    color:var(--rune);
    font-size:13px;
    text-transform:uppercase;
    opacity:0.75;
  }
  h1{
    font-size:2.1rem;
    margin:6px 0 4px;
    letter-spacing:0.5px;
    color:var(--rune-dark);
  }
  .subtitle{
    color:var(--ink-soft);
    font-size:0.95rem;
    font-style:italic;
  }

  .progress-bar{
    height:6px;
    background:var(--line);
    border-radius:4px;
    overflow:hidden;
    margin:20px 0 6px;
  }
  .progress-fill{
    height:100%;
    background:linear-gradient(90deg,var(--gold),var(--rune));
    width:0%;
    transition:width .35s ease;
  }
  .progress-label{
    display:flex;
    justify-content:space-between;
    font-size:0.8rem;
    color:var(--ink-soft);
    margin-bottom:18px;
  }

  .card{
    background:var(--card);
    border:1px solid var(--line);
    border-radius:6px;
    padding:26px 26px 22px;
    box-shadow:0 2px 0 var(--line), 0 12px 24px -18px rgba(43,36,24,0.4);
    position:relative;
  }
  .card::before{
    content:"";
    position:absolute;
    top:10px;left:10px;right:10px;bottom:10px;
    border:1px solid rgba(122,92,62,0.18);
    border-radius:3px;
    pointer-events:none;
  }
  .qnum{
    font-size:0.78rem;
    letter-spacing:2px;
    text-transform:uppercase;
    color:var(--gold);
    margin-bottom:6px;
  }
  .qtext{
    font-size:1.18rem;
    line-height:1.45;
    margin-bottom:18px;
    color:var(--ink);
  }
  .hint{
    font-size:0.82rem;
    color:var(--ink-soft);
    font-style:italic;
    margin:-10px 0 16px;
  }

  .options{
    display:flex;
    flex-direction:column;
    gap:10px;
  }
  .opt{
    display:flex;
    align-items:flex-start;
    gap:12px;
    padding:12px 14px;
    border:1px solid var(--line);
    border-radius:4px;
    background:#fbf7ec;
    cursor:pointer;
    transition:background .15s ease, border-color .15s ease, transform .1s ease;
  }
  .opt:hover{background:#f3ead0; border-color:var(--gold);}
  .opt.selected{border-color:var(--rune); background:#efe2c1;}
  .opt.correct{border-color:var(--ok); background:#e3ecdf;}
  .opt.incorrect{border-color:var(--bad); background:#f1dede;}
  .opt.reveal-correct-unselected{border-color:var(--ok); background:#eef4ec; opacity:0.85;}
  .opt .marker{
    flex:0 0 26px;
    height:26px;
    border-radius:50%;
    border:1.5px solid var(--rune);
    display:flex;
    align-items:center;
    justify-content:center;
    font-size:0.8rem;
    font-weight:600;
    color:var(--rune-dark);
    background:#fff8ea;
  }
  .opt.correct .marker{border-color:var(--ok); color:var(--ok); background:#e3ecdf;}
  .opt.incorrect .marker{border-color:var(--bad); color:var(--bad); background:#f1dede;}
  .opt-text{padding-top:2px; line-height:1.4;}

  .controls{
    display:flex;
    justify-content:space-between;
    align-items:center;
    margin-top:24px;
    gap:12px;
    flex-wrap:wrap;
  }
  button{
    font-family:inherit;
    font-size:0.95rem;
    padding:10px 20px;
    border-radius:4px;
    border:1px solid var(--rune-dark);
    background:var(--rune-dark);
    color:#f7f2e5;
    cursor:pointer;
    transition:background .15s ease, transform .1s ease;
  }
  button:hover{background:#3a2c1b; transform:translateY(-1px);}
  button:disabled{opacity:0.4; cursor:not-allowed; transform:none;}
  button.secondary{
    background:transparent;
    color:var(--rune-dark);
  }
  button.secondary:hover{background:rgba(122,92,62,0.1);}

  .feedback{
    margin-top:16px;
    padding:12px 14px;
    border-radius:4px;
    font-size:0.92rem;
    display:none;
  }
  .feedback.show{display:block;}
  .feedback.ok{background:#e3ecdf; color:var(--ok); border:1px solid #b9d0b8;}
  .feedback.bad{background:#f1dede; color:var(--bad); border:1px solid #dcb4b4;}

  .topbar{
    display:flex;
    justify-content:center;
    gap:10px;
    margin-bottom:10px;
    flex-wrap:wrap;
  }
  .pill{
    font-size:0.78rem;
    padding:6px 14px;
    border-radius:999px;
    border:1px solid var(--line);
    background:#fbf7ec;
    color:var(--ink-soft);
    cursor:pointer;
  }
  .pill.active{
    background:var(--rune-dark);
    color:#f7f2e5;
    border-color:var(--rune-dark);
  }

  .results{
    text-align:center;
    padding:20px 10px;
  }
  .score-ring{
    width:160px;height:160px;margin:10px auto 20px;
    border-radius:50%;
    display:flex;align-items:center;justify-content:center;
    font-size:2.1rem;
    font-weight:600;
    color:var(--rune-dark);
    background:conic-gradient(var(--gold) calc(var(--pct)*1%), var(--line) 0);
    position:relative;
  }
  .score-ring::before{
    content:"";
    position:absolute;
    width:126px;height:126px;
    border-radius:50%;
    background:var(--card);
  }
  .score-ring span{position:relative;}
  .missed-list{
    text-align:left;
    margin-top:20px;
  }
  .missed-item{
    padding:10px 0;
    border-bottom:1px solid var(--line);
    font-size:0.92rem;
  }
  .missed-item b{color:var(--rune-dark);}
  .missed-item .ans{color:var(--ok);}

  footer{
    text-align:center;
    margin-top:30px;
    font-size:0.78rem;
    color:var(--ink-soft);
    opacity:0.7;
  }

  @media (max-width:480px){
    .card{padding:20px 16px;}
    h1{font-size:1.6rem;}
    .score-ring{width:130px;height:130px;font-size:1.6rem;}
    .score-ring::before{width:100px;height:100px;}
  }
</style>
</head>
