const exam2answers = [[0],[0,1],[0],[0,1],[0,2,3],[3],[1,2,3],[2],[2],[0,2,3],[0,1],[0,2,3],[1,2,3],[2,3],[0,3],[1,3],[2],[0,1],[1,2],[1,2,3],[0,1,2],[0,2],[0,3],[0,2],[1]];

const exam2 = exam2raw.map((q,i)=>[q[0], q[1], exam2answers[i]]);

const banks = {
  exam1: {label:"Altklausur (Wischer)", data: exam1},
  exam2: {label:"Review Session (Peters)", data: exam2},
  all: {label:"Beide kombiniert", data: exam1.concat(exam2)}
};

let currentBankKey = "all";
let questions = [];
let current = 0;
let selected = [];
let checked = [];
let score = 0;

function shuffle(arr){
  const a = arr.slice();
  for(let i=a.length-1;i>0;i--){
    const j = Math.floor(Math.random()*(i+1));
    [a[i],a[j]]=[a[j],a[i]];
  }
  return a;
}

function initBank(key){
  currentBankKey = key;
  questions = banks[key].data;
  current = 0;
  selected = questions.map(()=>[]);
  checked = questions.map(()=>false);
  score = 0;
  document.getElementById('results').style.display='none';
  document.getElementById('quizArea').style.display='block';
  renderTopbar();
  renderQuestion();
}

function renderTopbar(){
  const tb = document.getElementById('topbar');
  tb.innerHTML = '';
  Object.keys(banks).forEach(key=>{
    const p = document.createElement('div');
    p.className = 'pill' + (key===currentBankKey ? ' active' : '');
    p.textContent = banks[key].label + ' (' + banks[key].data.length + ')';
    p.onclick = ()=>initBank(key);
    tb.appendChild(p);
  });
}

function renderQuestion(){
  const q = questions[current];
  document.getElementById('qnum').textContent = 'Frage ' + (current+1) + ' von ' + questions.length + (q[2].length>1 ? ' · Mehrfachauswahl' : ' · Eine Antwort');
  document.getElementById('qtext').textContent = q[0];
  document.getElementById('hint').textContent = q[2].length + ' richtige Antwort' + (q[2].length>1?'en':'');
  const optsDiv = document.getElementById('options');
  optsDiv.innerHTML = '';
  q[1].forEach((optText, idx)=>{
    const opt = document.createElement('div');
    opt.className = 'opt';
    opt.innerHTML = '<div class="marker">'+letters[idx]+'</div><div class="opt-text">'+optText+'</div>';
    opt.onclick = ()=>toggleOption(idx);
    optsDiv.appendChild(opt);
  });
  document.getElementById('feedback').className = 'feedback';
  document.getElementById('feedback').textContent = '';
  document.getElementById('nextBtn').style.display = 'none';
  document.getElementById('checkBtn').style.display = 'inline-block';
  document.getElementById('checkBtn').disabled = false;
  document.getElementById('prevBtn').disabled = current===0;

  if(checked[current]){
    showResult();
  } else {
    updateSelectionVisual();
  }

  updateProgress();
}

function toggleOption(idx){
  if(checked[current]) return;
  const arr = selected[current];
  const pos = arr.indexOf(idx);
  if(pos>=0) arr.splice(pos,1); else arr.push(idx);
  updateSelectionVisual();
}

function updateSelectionVisual(){
  const opts = document.querySelectorAll('.opt');
  opts.forEach((el,idx)=>{
    el.classList.toggle('selected', selected[current].includes(idx));
  });
}

function showResult(){
  const q = questions[current];
  const opts = document.querySelectorAll('.opt');
  const correctSet = new Set(q[2]);
  const selSet = new Set(selected[current]);
  opts.forEach((el,idx)=>{
    el.classList.remove('selected');
    if(correctSet.has(idx) && selSet.has(idx)){
      el.classList.add('correct');
    } else if(!correctSet.has(idx) && selSet.has(idx)){
      el.classList.add('incorrect');
    } else if(correctSet.has(idx) && !selSet.has(idx)){
      el.classList.add('reveal-correct-unselected');
    }
  });
  const isRight = correctSet.size===selSet.size && [...correctSet].every(x=>selSet.has(x));
  const fb = document.getElementById('feedback');
  fb.classList.add('show');
  if(isRight){
    fb.classList.add('ok'); fb.classList.remove('bad');
    fb.textContent = '✓ Richtig! ' + (q[2].length>1 ? 'Alle korrekten Antworten gefunden.' : '');
  } else {
    fb.classList.add('bad'); fb.classList.remove('ok');
    const correctLetters = q[2].map(i=>letters[i]).join(', ');
    fb.textContent = '✗ Nicht ganz — richtig wäre: ' + correctLetters;
  }
  document.getElementById('checkBtn').style.display = 'none';
  document.getElementById('nextBtn').style.display = 'inline-block';
}

document.getElementById('checkBtn').onclick = ()=>{
  if(selected[current].length===0) return;
  checked[current] = true;
  const q = questions[current];
  const correctSet = new Set(q[2]);
  const selSet = new Set(selected[current]);
  const isRight = correctSet.size===selSet.size && [...correctSet].every(x=>selSet.has(x));
  if(isRight) score++;
  updateProgress();
  showResult();
};

document.getElementById('nextBtn').onclick = ()=>{
  if(current < questions.length-1){
    current++;
    renderQuestion();
  } else {
    showResults();
  }
};

document.getElementById('prevBtn').onclick = ()=>{
  if(current>0){
    current--;
    renderQuestion();
  }
};

function updateProgress(){
  const answered = checked.filter(Boolean).length;
  const pct = Math.round((current)/(questions.length-1||1)*100);
  document.getElementById('progressFill').style.width = ((current)/(questions.length-1||1)*100) + '%';
  document.getElementById('progressText').textContent = 'Frage ' + (current+1) + ' / ' + questions.length;
  document.getElementById('scoreText').textContent = 'Punkte: ' + score + ' / ' + answered;
}

function showResults(){
  document.getElementById('quizArea').style.display='none';
  const res = document.getElementById('results');
  res.style.display='block';
  const total = questions.length;
  const pct = Math.round(score/total*100);
  document.getElementById('scoreRing').style.setProperty('--pct', pct);
  document.getElementById('scorePct').textContent = pct + '%';
  document.getElementById('scoreSummary').innerHTML = '<p style="font-size:1.05rem;">Du hast <b>' + score + ' von ' + total + '</b> Fragen richtig beantwortet.</p>';

  const missedDiv = document.getElementById('missedList');
  missedDiv.innerHTML = '';
  questions.forEach((q,idx)=>{
    const correctSet = new Set(q[2]);
    const selSet = new Set(selected[idx]);
    const isRight = correctSet.size===selSet.size && [...correctSet].every(x=>selSet.has(x));
    if(!isRight){
      const div = document.createElement('div');
      div.className = 'missed-item';
      div.innerHTML = '<b>Frage '+(idx+1)+':</b> ' + q[0] + '<br><span class="ans">Richtig: ' + q[2].map(i=>letters[i]+') '+q[1][i]).join(' · ') + '</span>';
      missedDiv.appendChild(div);
    }
  });
  if(missedDiv.innerHTML===''){
    missedDiv.innerHTML = '<p style="text-align:center; color:var(--ok); font-weight:600;">Alle Fragen richtig — sehr gut gerüstet für die Klausur!</p>';
  }
}

document.getElementById('restartBtn').onclick = ()=>initBank(currentBankKey);

// init
initBank('all');
</script>
